# Database URL
DATABASE_URL="postgresql://user:password@localhost:5432/db_name"

# Cloudflare R2 / S3 Configuration
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
S3_API="https://your_account_id.r2.cloudflarestorage.com"
CLOUDFLARE_ACCESS_KEY="your_access_key"
CLOUDFLARE_SECRET_KEY="your_secret_key"
BUCKET_NAME="your_bucket_name"

# Redis Configuration
REIDS_QUEUE_NAME="ion-build-queue"

# Auth (GitHub)
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your_better_auth_secret"

# Backend Service Ports
REQUEST_BACKEND_PORT=3003
REPO_BACKEND_PORT=3002
WEBSOCKET_PORT=8081

# Public API Environment Variables (Frontend)
NEXT_PUBLIC_REQUEST_BACKEND_URL="http://localhost:3003"
NEXT_PUBLIC_REPO_BACKEND_URL="http://localhost:3002"
NEXT_PUBLIC_WEBSOCKET_URL="ws://localhost:8081"

# Internal Origins and Redirects
FRONTEND_URL="http://localhost:3000"
MAINORIGINS2="http://localhost:3002"
MAINORIGINS3="http://localhost:3003"